# npm Configuration
# Copy this file to .npmrc if you need to publish locally, and replace YOUR_NPM_TOKEN
# with an npm access token that can publish to the @schaake-solutions org.
# Do not commit .npmrc; it is gitignored because it contains credentials.

@schaake-solutions:registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=YOUR_NPM_TOKEN
